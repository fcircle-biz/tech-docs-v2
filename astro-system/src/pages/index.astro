---
// tech-docs-v2 ランディングページ。
// guideRegistry を走査し、全 TechGuide をカード一覧としてデータ駆動で描画する
// （教材を追加すると自動でカードが増える。ハードコードはしない）。
// スタンドアロンページのため <head> で Tailwind/Fonts/Font Awesome を自己完結読込する。
import { guideRegistry } from '../data/guides';

const base = import.meta.env.BASE_URL;

// 全分類・全 slug を平坦化して TechGuide の配列にする。
const guides = Object.values(guideRegistry).flatMap((bySlug) => Object.values(bySlug));

// 各ガイドの先頭章（章番号 1、無ければ最初の章）へのリンクを作る。
const cards = guides.map((g) => {
  const first = g.chapters.find((c) => c.number === 1) ?? g.chapters[0];
  const href = `${base}guide/${g.category}/${g.slug}/${first.file}`;
  return { g, href };
});

const title = 'tech-docs-v2 — IT・ソフトウェア開発の学習ガイド';
const description =
  'IT・ソフトウェア開発の体系的な日本語学習ガイド集。初心者向けに章立てで学べる技術教材を公開しています。';
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Tailwind CSS CDN（版固定） -->
    <script is:inline src="https://cdn.tailwindcss.com/3.4.17"></script>

    <!-- Google Fonts - Noto Sans JP -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Font Awesome Icons -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />

    <style is:inline>
      :root {
        font-family: 'Noto Sans JP', sans-serif;
      }
      .font-mono {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
      }
    </style>
  </head>
  <body class="font-sans bg-slate-50 text-slate-800 antialiased">
    <!-- ヘッダー（グラファイトガラス） -->
    <header class="bg-slate-900 text-white">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <div class="flex items-center gap-3">
          <div
            class="w-12 h-12 rounded-xl flex items-center justify-center bg-gradient-to-br from-violet-500 to-cyan-500 shadow-lg"
          >
            <i class="fas fa-terminal text-xl text-white"></i>
          </div>
          <div class="flex flex-col">
            <span class="text-lg font-bold tracking-wide font-mono">tech-docs-v2</span>
            <span class="text-xs text-slate-300">IT・ソフトウェア開発の学習ガイド</span>
          </div>
        </div>
      </div>
    </header>

    <main>
      <!-- ヒーロー -->
      <section class="bg-slate-900 text-white">
        <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 pt-8">
          <p
            class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/10 text-xs font-semibold tracking-wider uppercase mb-5"
          >
            <i class="fas fa-book-open text-cyan-300"></i>
            Learning Guides
          </p>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold leading-tight">
            <span
              class="bg-gradient-to-r from-violet-400 to-cyan-400 bg-clip-text text-transparent"
              >技術学習ガイド</span
            >
          </h1>
          <p class="mt-5 max-w-2xl text-base sm:text-lg text-slate-300 leading-relaxed">
            初心者向けに章立てで構成された学習教材を公開しています。気になるガイドを選んで、第1章から順に学習を始めましょう。
          </p>
        </div>
      </section>

      <!-- ガイド一覧 -->
      <section class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
        <div class="flex items-end justify-between mb-8">
          <h2 class="text-2xl font-bold text-slate-900">学習ガイド一覧</h2>
          <span class="text-sm text-slate-500">{cards.length} 件</span>
        </div>

        {
          cards.length === 0 ? (
            <p class="text-slate-500">現在公開中の学習ガイドはありません。</p>
          ) : (
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
              {cards.map(({ g, href }) => (
                <a
                  href={href}
                  class="group relative flex flex-col rounded-2xl bg-white border border-slate-200 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden"
                >
                  {/* primary→cyan のヘアラインレール */}
                  <span
                    class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-violet-500 to-cyan-500"
                    style={`background: linear-gradient(to right, ${g.primary[500]}, #06b6d4);`}
                  />
                  <div class="p-6 flex flex-col h-full">
                    <div class="flex items-center gap-4 mb-4">
                      <div
                        class="w-14 h-14 rounded-xl flex items-center justify-center shadow-md flex-shrink-0"
                        style={`background: linear-gradient(135deg, ${g.splashStop0}, ${g.splashStop1});`}
                      >
                        <i class:list={[g.iconStyle ?? 'fas', g.icon, 'text-2xl', 'text-white']} />
                      </div>
                      <div class="min-w-0">
                        <h3 class="text-lg font-bold text-slate-900 truncate">
                          {g.techTitle}
                        </h3>
                        <p class="text-xs text-slate-500 mt-0.5">{g.categoryLabel}</p>
                      </div>
                    </div>

                    <div class="flex flex-wrap items-center gap-2 mb-5">
                      <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-slate-100 text-slate-700 text-xs font-medium">
                        <i class="fas fa-star text-amber-400 text-[10px]" />
                        {g.level}
                      </span>
                      <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-slate-100 text-slate-700 text-xs font-medium">
                        <i class="fas fa-clock text-[10px]" />
                        {g.totalTime}
                      </span>
                      <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-slate-100 text-slate-700 text-xs font-medium">
                        <i class="fas fa-list-ol text-[10px]" />
                        全{g.chapters.length}章
                      </span>
                    </div>

                    <span class="mt-auto inline-flex items-center gap-2 text-sm font-semibold text-slate-700 group-hover:text-slate-900 transition-colors">
                      第1章から学習を始める
                      <i class="fas fa-arrow-right text-xs group-hover:translate-x-1 transition-transform" />
                    </span>
                  </div>
                </a>
              ))}
            </div>
          )
        }
      </section>
    </main>

    <!-- フッター -->
    <footer class="bg-slate-800 text-slate-300">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-4">
          <p class="text-sm text-center md:text-left">
            &copy; 2026 F-Circle. All rights reserved.<br />
            本資料はAIツールを活用し、人間による編集・監修のもと作成されています。
          </p>
          <div class="flex items-center gap-4">
            <a
              href="https://github.com/fcircle-biz/tech-docs-v2"
              target="_blank"
              rel="noopener"
              class="hover:text-white transition-colors"
            >
              <i class="fab fa-github text-xl"></i>
            </a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
